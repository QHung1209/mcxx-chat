{
  "name": "mcxx-chat",
  "version": "0.0.1",
  "description": "mcxx Chat — standalone chat + auth service (Telegram-like)",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typeorm": "npx typeorm -d dist/datasource.js",
    "migration:generate": "npm run build && npm run typeorm -- migration:generate",
    "migration:create": "npx typeorm migration:create",
    "migration:run": "npm run build && npm run typeorm -- migration:run",
    "migration:revert": "npm run build && npm run typeorm -- migration:revert"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1036.0",
    "@aws-sdk/client-sesv2": "^3.1043.0",
    "@aws-sdk/lib-storage": "^3.1036.0",
    "@aws-sdk/s3-request-presigner": "^3.1036.0",
    "@fastify/busboy": "^3.2.0",
    "@nestjs-modules/ioredis": "^2.2.1",
    "@nestjs-modules/mailer": "^2.3.4",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^11.1.19",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.18.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "googleapis": "^171.4.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "link-preview-js": "^4.0.3",
    "luxon": "^3.5.0",
    "nestjs-i18n": "^10.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "redis": "^5.0.14",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "typeorm": "^0.3.28",
    "uuidv7": "^1.2.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "dotenv": "^16.4.7",
    "eslint": "9.26.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
