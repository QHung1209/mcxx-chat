APP_NAME=mcxx-chat
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=local
APP_LOCALE=en
APP_ZONE=Asia/Ho_Chi_Minh

# JWT
SECRETKEY=change-me-access-secret
EXPIRESIN=86400
SECRETKEY_REFRESH=change-me-refresh-secret
EXPIRESIN_REFRESH=2592000

# MAIL (SES hoặc SMTP). MAIL_DRIVER=SMTP để dùng host bên dưới.
MAIL_DRIVER=SMTP
MAIL_HOST=
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=no-reply@mcxx-chat.local

FE_URL=http://localhost:5173

# Google OAuth (tùy chọn)
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=
GOOGLE_AUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback

# AWS S3 (lưu media/avatar/đính kèm)
FILESYSTEM_DRIVER=s3
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_PUBLIC_BUCKET_NAME=

# DATABASE POSTGRESQL
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=mcxx_chat
DB_USERNAME=mcxx
DB_PASSWORD=mcxx

# REDIS
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_INDEX=0
